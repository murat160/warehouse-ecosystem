FROM node:20-alpine AS builder
WORKDIR /repo
COPY package.json package-lock.json* tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
RUN npm install --no-audit --no-fund

# Build all 7 frontend apps with their nginx base path
RUN VITE_API_URL=/api VITE_BASE=/admin/      npx --workspace apps/admin-panel      vite build --base=/admin/
RUN VITE_API_URL=/api VITE_BASE=/staff/      npx --workspace apps/staff-app        vite build --base=/staff/
RUN VITE_API_URL=/api VITE_BASE=/supervisor/ npx --workspace apps/supervisor-panel vite build --base=/supervisor/
RUN VITE_API_URL=/api VITE_BASE=/seller/     npx --workspace apps/seller-app       vite build --base=/seller/
RUN VITE_API_URL=/api VITE_BASE=/courier/    npx --workspace apps/courier-app      vite build --base=/courier/
RUN VITE_API_URL=/api VITE_BASE=/customer/   npx --workspace apps/customer-app     vite build --base=/customer/
RUN VITE_API_URL=/api VITE_BASE=/pickup/     npx --workspace apps/pickup-point-app vite build --base=/pickup/

FROM nginx:1.27-alpine
COPY --from=builder /repo/apps/admin-panel/dist      /usr/share/nginx/html/admin
COPY --from=builder /repo/apps/staff-app/dist        /usr/share/nginx/html/staff
COPY --from=builder /repo/apps/supervisor-panel/dist /usr/share/nginx/html/supervisor
COPY --from=builder /repo/apps/seller-app/dist       /usr/share/nginx/html/seller
COPY --from=builder /repo/apps/courier-app/dist      /usr/share/nginx/html/courier
COPY --from=builder /repo/apps/customer-app/dist     /usr/share/nginx/html/customer
COPY --from=builder /repo/apps/pickup-point-app/dist /usr/share/nginx/html/pickup
COPY deploy/nginx/wms.docker.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
