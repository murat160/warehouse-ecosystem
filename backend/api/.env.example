NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0

# JWT
JWT_SECRET=change_me_in_production_min_32_chars_long_xxxxxxxx
JWT_EXPIRES_IN=12h

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL="file:./prisma/wms.db"
# Example PostgreSQL:
# DATABASE_URL="postgresql://wms:wms_password@localhost:5432/wms?schema=public"

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177
