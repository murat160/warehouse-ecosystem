# Backend API
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change_me_in_production_min_32_chars_long
JWT_EXPIRES_IN=12h

# Database (SQLite for dev, PostgreSQL for prod)
# SQLite: file:./prisma/wms.db
# PostgreSQL: postgresql://user:pass@localhost:5432/wms
DATABASE_URL="file:./prisma/wms.db"

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# Frontend apps point to API via this URL
VITE_API_URL=http://localhost:4000
