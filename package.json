{
  "name": "warehouse-ecosystem",
  "version": "0.2.0",
  "private": true,
  "description": "Warehouse + marketplace ecosystem: backend/API + 7 apps (admin, staff, supervisor, seller, courier, customer, pickup-point)",
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api":        "npm --workspace backend/api run dev",
    "dev:admin":      "npm --workspace apps/admin-panel run dev",
    "dev:staff":      "npm --workspace apps/staff-app run dev",
    "dev:supervisor": "npm --workspace apps/supervisor-panel run dev",
    "dev:seller":     "npm --workspace apps/seller-app run dev",
    "dev:courier":    "npm --workspace apps/courier-app run dev",
    "dev:customer":   "npm --workspace apps/customer-app run dev",
    "dev:pickup":     "npm --workspace apps/pickup-point-app run dev",
    "dev": "npm-run-all --parallel dev:api dev:admin dev:staff dev:supervisor dev:seller dev:courier dev:customer dev:pickup",

    "build:api":         "npm --workspace backend/api run build",
    "build:admin":       "npm --workspace apps/admin-panel run build",
    "build:staff":       "npm --workspace apps/staff-app run build",
    "build:supervisor":  "npm --workspace apps/supervisor-panel run build",
    "build:seller":      "npm --workspace apps/seller-app run build",
    "build:courier":     "npm --workspace apps/courier-app run build",
    "build:customer":    "npm --workspace apps/customer-app run build",
    "build:pickup":      "npm --workspace apps/pickup-point-app run build",
    "build:apps": "npm-run-all --parallel build:admin build:staff build:supervisor build:seller build:courier build:customer build:pickup",
    "build": "npm-run-all build:api build:apps",

    "db:generate": "npm --workspace backend/api run db:generate",
    "db:migrate":  "npm --workspace backend/api run db:migrate",
    "db:seed":     "npm --workspace backend/api run db:seed",
    "db:reset":    "npm --workspace backend/api run db:reset"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
